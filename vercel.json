{
  "version": 2,
  "builds": [
    {
      "src": "api/webhook.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.py"
    },
    {
      "src": "/",
      "dest": "/api/webhook.py"
    }
  ],
  "env": {
    "BOT_TOKEN": "${BOT_TOKEN}",
    "GROQ_API_KEY": "${GROQ_API_KEY}"
  }
}
